{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🎬 Detector - Modo Conveyor",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/detector/run.py",
      "args": ["--camera-id", "0", "--mode", "conveyor"],
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}/detector",
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    {
      "name": "📱 Webcam MacBook",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/detector/run.py",
      "args": ["--camera-id", "0", "--mode", "live"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/detector",
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    {
      "name": "🍎 Continuity Camera (iPhone)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/detector/run.py",
      "args": ["--camera-id", "1", "--mode", "conveyor"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/detector",
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  ]
}
